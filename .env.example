# ============================================================
# MatchKit — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# All settings have sensible defaults for local development.

# ==================== Branding (white-label) ====================
APP_NAME=MatchKit
APP_TAGLINE=Cofounder & Interest Matching Platform
SUPPORT_EMAIL=support@example.com
PROFILE_BASE_URL=https://example.com
PROFILE_URL_PATTERN=/members/{slug}/

# ==================== Embedding Provider ====================
# Azure OpenAI credentials for generating semantic embeddings.
# Leave empty to disable embedding-based matching.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ==================== Database ====================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/matchkit

# ==================== Email ====================
# Configure at least one provider to enable email digests.
MANDRILL_API_KEY=
SENDGRID_API_KEY=
EMAIL_FROM_ADDRESS=matches@example.com
EMAIL_FROM_NAME=MatchKit

# ==================== CRM Integration (optional) ====================
# Set CRM_ENABLED=true and provide credentials to enable CRM sync.
CRM_ENABLED=false
CRM_INSTANCE_URL=
CRM_CLIENT_ID=
CRM_CLIENT_SECRET=
CRM_API_VERSION=v59.0

# ==================== API ====================
API_KEY=dev-api-key-change-in-production
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ==================== Matching ====================
MIN_MATCH_SCORE=0.4
MAX_MATCHES_PER_EMAIL=5
SCORING_CONFIG_PATH=config/scoring.yml

# ==================== AI Features ====================
AI_EXPLANATIONS_ENABLED=true
AI_ICEBREAKERS_ENABLED=true
AI_ONBOARDING_ENABLED=true
AI_NUDGES_ENABLED=true
AI_PROFILE_ENRICHMENT_ENABLED=true

# ==================== Chat ====================
CHAT_ENABLED=true
CHAT_MAX_MESSAGE_LENGTH=2000
CHAT_HISTORY_LIMIT=100

# ==================== Scheduler ====================
WEEKLY_EMAIL_DAY=monday
WEEKLY_EMAIL_HOUR=9
EMAIL_FREQUENCY=weekly
MONTHLY_EMAIL_DAY=1
MATCH_REFRESH_FREQUENCY=weekly
NUDGE_FREQUENCY=weekly
